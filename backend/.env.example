# ── Wheel Advisor — Backend Environment ──────────────────────────────────────
# Copy this file to .env and fill in your values.

# Server bind address (host:port)
BIND_ADDR=0.0.0.0:9000

# Data source for options chains: yahoo | api | json
DATA_SOURCE=yahoo

# Path to mock JSON data (only used when DATA_SOURCE=json)
MOCK_DATA_DIR=../data/mock

# MarketData.app API key (only used when DATA_SOURCE=api)
# OPTIONS_API_KEY=your_key_here

# Alpha Vantage API key for news sentiment
# Get a free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Rust log filter
RUST_LOG=wheel_advisor=debug,tower_http=debug
